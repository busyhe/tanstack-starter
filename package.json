{
  "name": "tanstack-starter",
  "private": true,
  "type": "module",
  "version": "1.0.1",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "check-types": "turbo check-types",
    "clean": "node ./scripts/clean.mjs",
    "commit": "czg",
    "dev": "turbo dev",
    "format": "prettier --cache --ignore-unknown --write .",
    "format:check": "prettier --cache --ignore-unknown --check .",
    "lint": "pnpm lint:root && turbo lint",
    "lint:root": "eslint . --max-warnings 0",
    "release": "node ./scripts/release-preflight.mjs && pnpm verify && bumpp package.json apps/*/package.json && node ./scripts/release-push.mjs",
    "scaffold:init": "node ./scripts/init.mjs",
    "start": "pnpm --filter www start",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "node ./scripts/e2e.mjs",
    "verify": "pnpm format:check && pnpm lint && pnpm check-types && pnpm test:coverage && pnpm build && pnpm test:e2e"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "bumpp": "catalog:",
    "czg": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "lefthook": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "core-js-pure",
      "esbuild",
      "lefthook",
      "lightningcss",
      "sharp"
    ],
    "overrides": {
      "@babel/core@>=7 <7.29.6": "7.29.7",
      "brace-expansion@>=1 <2": "1.1.13",
      "defu@>=6 <6.1.5": "6.1.7",
      "flatted@>=3 <3.4.2": "3.4.2",
      "js-yaml@>=4 <4.2.0": "4.3.0",
      "launch-editor@>=2 <2.14.1": "2.14.1",
      "minimatch@>=3 <3.1.4": "3.1.5",
      "shell-quote@>=1 <1.8.4": "1.8.4",
      "undici@>=7 <7.28.0": "7.28.0",
      "ws@>=8 <8.21.0": "8.21.0",
      "yaml@>=2 <2.8.3": "2.8.4"
    }
  }
}
