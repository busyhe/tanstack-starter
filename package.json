{
  "name": "tanstack-starter",
  "private": true,
  "type": "module",
  "version": "0.1.1",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "check-types": "turbo check-types",
    "clean": "node ./scripts/clean.mjs",
    "commit": "czg",
    "dev": "turbo dev",
    "format": "prettier --cache --ignore-unknown --write .",
    "format:check": "prettier --cache --ignore-unknown --check .",
    "lint": "pnpm lint:root && turbo lint",
    "lint:root": "eslint . --max-warnings 0",
    "release": "pnpm verify && bumpp package.json apps/*/package.json",
    "scaffold:init": "node ./scripts/init.mjs",
    "start": "pnpm --filter www start",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "node ./scripts/e2e.mjs",
    "verify": "pnpm format:check && pnpm lint && pnpm check-types && pnpm test:coverage && pnpm build && pnpm test:e2e"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "bumpp": "catalog:",
    "czg": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "lefthook": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "core-js-pure",
      "esbuild",
      "lefthook",
      "lightningcss",
      "sharp"
    ]
  }
}
